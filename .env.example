# Supabase — https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build OAuth redirect URLs (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth is configured inside Supabase Auth providers, not here —
# see https://supabase.com/docs/guides/auth/social-login/auth-google

# --- AI generation providers (add the ones you use, wire keys via /admin/api-manager instead of env in production) ---
RUNWAY_API_KEY=
FLUX_API_KEY=
ELEVENLABS_API_KEY=

# --- Publish destinations ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
